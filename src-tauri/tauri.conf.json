{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastClaude",
  "version": "0.1.0",
  "identifier": "com.fastclaude.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FastClaude",
        "width": 800,
        "height": 600,
        "minWidth": 520,
        "minHeight": 360,
        "decorations": false,
        "resizable": true,
        "shadow": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/inevitable21/FastClaude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREQzA3NjZFNkI0RjIyRUUKUldUdUlrOXJibmJBVFZyU3RZRDZqSUpvMWRrN0VmTU9EMStmNU9GYVlXaUhidTdqcjZQN1FZdU0K"
    }
  }
}
